{
  "name": "@sbakolis/organize-pr-topics",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "organize-pr-topics": "./bin/organize-pr-topics.mjs"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "templates",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check-gh": "node scripts/check-gh.mjs",
    "prepare-session": "node scripts/prepare-session.mjs",
    "dev": "node --import tsx app/server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"import('node:fs').then(({rmSync}) => rmSync('dist', { recursive: true, force: true }))\"",
    "build:ui": "vite build",
    "build:server": "tsup --config tsup.config.ts",
    "build": "npm run clean && npm run build:ui && npm run build:server",
    "prepack": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
